# Copy this file to ".env" and fill in the values.

# Port the API + app are served on
PORT=4000

# Secret used to sign login tokens. Use a long, random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Google Sign-In (optional). Leave blank to use the simulated Google button.
# Create one at https://console.cloud.google.com  ->  APIs & Services  ->  Credentials
# -> Create OAuth client ID -> "Web application".
# Add  http://localhost:4000  to "Authorized JavaScript origins".
GOOGLE_CLIENT_ID=
