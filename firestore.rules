rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each Packet Card profile lives at  cards/{cardId}
    match /cards/{cardId} {

      // Anyone can READ a card — profiles are public.
      allow read: if true;

      // CLAIMING a card (first time): the document must not exist yet,
      // the user must be signed in, and they must set ownerUid to themselves.
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;

      // EDITING a card: only the owner can update, and ownerUid can't change.
      allow update: if request.auth != null
                    && resource.data.ownerUid == request.auth.uid
                    && request.resource.data.ownerUid == resource.data.ownerUid;

      // No deleting from the client.
      allow delete: if false;
    }
  }
}
